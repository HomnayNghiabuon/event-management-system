# ============================================================
# Event Management Server – Hướng dẫn cấu hình môi trường
# ============================================================
#
# CÁCH SỬ DỤNG:
#   1. Copy file này thành .env
#      Windows:  copy .env.example .env
#      Mac/Linux: cp .env.example .env
#
#   2. Mở file .env vừa tạo, điền các giá trị có ghi "← SỬA"
#
#   3. KHÔNG commit file .env lên git
#      (đã được thêm vào .gitignore, yên tâm)
#
# ============================================================
# LEGEND:
#   [GIỮ NGUYÊN]  = Không cần sửa, dùng giá trị mặc định
#   [← SỬA]      = Bắt buộc phải điền giá trị của bạn
#   [TÙY CHỌN]   = Có thể thay đổi nếu muốn
# ============================================================


# ────────────────────────────────────────
# SERVER
# ────────────────────────────────────────

# Port server lắng nghe
# [TÙY CHỌN] Đổi nếu port 8081 bị chiếm bởi app khác
SERVER_PORT=8081


# ────────────────────────────────────────
# DATABASE – MySQL
# ────────────────────────────────────────
#
# Trước khi chạy server, tạo database trong MySQL:
#   CREATE DATABASE eventdb CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#

# [TÙY CHỌN] Đổi "localhost:3306" nếu MySQL chạy trên máy khác hoặc port khác
#            Đổi "eventdb" nếu bạn đặt tên database khác
DB_URL=jdbc:mysql://localhost:3306/eventdb?useSSL=false&serverTimezone=Asia/Ho_Chi_Minh&allowPublicKeyRetrieval=true

# [GIỮ NGUYÊN]
DB_DRIVER=com.mysql.cj.jdbc.Driver

# [TÙY CHỌN] Đổi nếu MySQL của bạn dùng username khác (không phải root)
DB_USERNAME=root

# [← SỬA] Điền password MySQL của bạn vào đây
#          Nếu MySQL không có password thì để trống: DB_PASSWORD=
DB_PASSWORD=


# ────────────────────────────────────────
# JPA / HIBERNATE
# ────────────────────────────────────────

# [GIỮ NGUYÊN]
JPA_PLATFORM=org.hibernate.dialect.MySQLDialect

# Hành vi tạo bảng khi khởi động:
#   update      → Tự tạo bảng mới / cập nhật schema, giữ data cũ  ← DÙNG CHO DEV
#   validate    → Chỉ kiểm tra schema, không sửa gì cả            ← DÙNG CHO PROD
#   create-drop → Xóa và tạo lại toàn bộ mỗi lần chạy            ← MẤT DATA
# [GIỮ NGUYÊN] cho môi trường dev
JPA_DDL_AUTO=update

# In câu SQL ra console (true = dễ debug, false = console sạch hơn)
# [TÙY CHỌN]
JPA_SHOW_SQL=true

# [GIỮ NGUYÊN] H2 Console không dùng khi kết nối MySQL
H2_CONSOLE_ENABLED=false


# ────────────────────────────────────────
# JWT – JSON Web Token
# ────────────────────────────────────────

# Khóa bí mật dùng để ký JWT (Base64 encoded)
# [← SỬA nếu deploy production]
#   Tạo secret mới bằng lệnh: openssl rand -base64 64
#   Giá trị dưới đây chỉ dùng cho môi trường dev/test
#   TUYỆT ĐỐI không dùng giá trị này trên production
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970

# Thời hạn access token tính bằng milliseconds
# 3600000 = 1 giờ  |  86400000 = 24 giờ
# [TÙY CHỌN]
JWT_EXPIRATION=3600000

# Thời hạn refresh token tính bằng milliseconds
# 604800000 = 7 ngày
# [TÙY CHỌN]
JWT_REFRESH_EXPIRATION=604800000


# ────────────────────────────────────────
# EMAIL / SMTP
# ────────────────────────────────────────
#
# Để gửi email thông báo cho người tham dự.
# Nếu không cấu hình, hệ thống vẫn chạy bình thường
# nhưng email sẽ không được gửi (chỉ lưu log DB).
#
# Hướng dẫn tạo Gmail App Password:
#   1. Bật 2-Step Verification tại myaccount.google.com/security
#   2. Vào App passwords → Tạo password cho "Mail"
#   3. Điền password 16 ký tự vào MAIL_PASSWORD bên dưới
#

# [← SỬA] SMTP server (mặc định Gmail)
MAIL_HOST=smtp.gmail.com

# [GIỮ NGUYÊN] Port TLS của Gmail
MAIL_PORT=587

# [← SỬA] Email Gmail của bạn
MAIL_USERNAME=your_email@gmail.com

# [← SỬA] App Password 16 ký tự (không phải password Gmail thường)
MAIL_PASSWORD=
