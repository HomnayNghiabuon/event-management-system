# ============================================================
# Event Management Server – Environment Variables
# ============================================================
# Hướng dẫn:
#   1. Copy file này thành .env  (cp .env.example .env)
#   2. Điền giá trị thực vào .env
#   3. KHÔNG commit .env lên git (đã có trong .gitignore)
# ============================================================

# --- Server ---
SERVER_PORT=8081

# --- Database (Dev: H2 in-memory) ---
DB_URL=jdbc:h2:mem:eventdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
DB_DRIVER=org.h2.Driver
DB_USERNAME=sa
DB_PASSWORD=

# --- Database (Production: MySQL) ---
# Bỏ comment các dòng dưới khi deploy production:
# DB_URL=jdbc:mysql://localhost:3306/event_management?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
# DB_DRIVER=com.mysql.cj.jdbc.Driver
# DB_USERNAME=root
# DB_PASSWORD=your_password_here

# --- JPA ---
JPA_PLATFORM=org.hibernate.dialect.H2Dialect
# Production MySQL: JPA_PLATFORM=org.hibernate.dialect.MySQLDialect
JPA_DDL_AUTO=create-drop
# Production: JPA_DDL_AUTO=validate
JPA_SHOW_SQL=true
# Production: JPA_SHOW_SQL=false

# --- H2 Console (chỉ dùng khi dev) ---
H2_CONSOLE_ENABLED=true
# Production: H2_CONSOLE_ENABLED=false

# --- JWT ---
# QUAN TRỌNG: Đổi JWT_SECRET thành chuỗi Base64 bí mật riêng khi production
# Tạo secret mới: openssl rand -base64 64
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000
